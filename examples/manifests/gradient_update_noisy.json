{
  "manifest_version": "0.1",
  "name": "noisy-gradient-update",
  "description": "Finite-difference gradient update using a deterministic noisy backend.",
  "experiment": "gradient_update",
  "backend": {
    "type": "noisy",
    "base": {
      "type": "pennylane"
    },
    "noise": 0.05,
    "seed": 42
  },
  "num_clients": 2,
  "num_rounds": 3,
  "initial_theta": 0.5,
  "learning_rate": 0.1,
  "target": 0.0,
  "epsilon": 0.001
}
